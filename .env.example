# Copy this file to .env and fill in the values before running the app.
# See README.md -> "Настройка окружения" for details.

# SQLite by default (via @prisma/adapter-libsql, no native build required).
# Swap for a Postgres/Turso URL in production.
DATABASE_URL="file:./dev.db"

# Secret used by NextAuth (Auth.js) to sign session JWTs.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Used only once by `npm run db:seed` to create the imam/admin account for the
# first seeded mosque ("Байкен"). One admin account = one mosque.
SEED_ADMIN_EMAIL="imam@jummatime.kz"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Имам"

# Same, but for the second seeded mosque ("Абу-Бакр") — demonstrates multi-mosque
# support. Change the passwords (or drop this account) before real use.
SEED_ADMIN2_EMAIL="imam2@jummatime.kz"
SEED_ADMIN2_PASSWORD="ChangeMe123!"
SEED_ADMIN2_NAME="Имам 2"
