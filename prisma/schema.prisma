// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum ContentCategory {
  SUNNAH
  RECOMMENDED_ACTION
  REMINDER
  FRIDAY_VIRTUE
  AL_KAHF
}

model Mosque {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  logoUrl   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  adminUsers    AdminUser[]
  khutbahs      Khutbah[]
  contentBlocks ContentBlock[]
}

model AdminUser {
  id           String   @id @default(cuid())
  mosqueId     String
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())

  mosque Mosque @relation(fields: [mosqueId], references: [id])
}

model Khutbah {
  id            String   @id @default(cuid())
  mosqueId      String
  slug          String   @unique
  date          DateTime
  published     Boolean  @default(true)
  originalLocale String  @default("kk")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  mosque       Mosque @relation(fields: [mosqueId], references: [id])
  translations KhutbahTranslation[]

  @@index([mosqueId, date])
}

model KhutbahTranslation {
  id        String  @id @default(cuid())
  khutbahId String
  locale    String
  title     String
  summary   String
  body      String

  khutbah Khutbah @relation(fields: [khutbahId], references: [id], onDelete: Cascade)

  @@unique([khutbahId, locale])
}

model QuranAyah {
  id              String   @id @default(cuid())
  surahNumber     Int
  ayahNumber      Int
  textArabic      String
  transliteration String

  translations QuranAyahTranslation[]

  @@unique([surahNumber, ayahNumber])
}

model QuranAyahTranslation {
  id      String @id @default(cuid())
  ayahId  String
  locale  String
  text    String

  ayah QuranAyah @relation(fields: [ayahId], references: [id], onDelete: Cascade)

  @@unique([ayahId, locale])
}

model ContentBlock {
  id        String          @id @default(cuid())
  mosqueId  String
  category  ContentCategory
  order     Int             @default(0)
  published Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  mosque       Mosque @relation(fields: [mosqueId], references: [id])
  translations ContentTranslation[]

  @@index([mosqueId, category, order])
}

model ContentTranslation {
  id             String @id @default(cuid())
  contentBlockId String
  locale         String
  title          String
  body           String

  contentBlock ContentBlock @relation(fields: [contentBlockId], references: [id], onDelete: Cascade)

  @@unique([contentBlockId, locale])
}
